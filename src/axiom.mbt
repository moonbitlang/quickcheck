// `Equivalence[T]` is declared in `types.mbt`. Methods and the `Show`
// impl for it live here.

///|
pub impl[T : Show] Show for Equivalence[T] with output(self, logger) {
  logger.write_string("{lhs: ")
  self.lhs.output(logger)
  logger.write_string(", rhs: ")
  self.rhs.output(logger)
  logger.write_string("}")
}

///|
/// Build an `Equivalence` asserting that `lhs` and `rhs` should be
/// equal under whatever relation the property checker uses.
pub fn[T] Equivalence::new(lhs : T, rhs : T) -> Equivalence[T] {
  { lhs, rhs }
}

///|
/// Functor `fmap` on both sides: `Equivalence::fmap({a, b}, f)` is
/// `{f(a), f(b)}`. Useful for wrapping a law in a coercion, e.g.
/// comparing two `Array`s via `.to_list()`.
pub fn[T, U] Equivalence::fmap(
  self : Equivalence[T],
  f : (T) -> U,
) -> Equivalence[U] {
  { lhs: f(self.lhs), rhs: f(self.rhs) }
}

///|
/// Monadic bind on an `Equivalence`: `f(lhs).lhs` and `f(rhs).rhs`.
/// Asymmetric on purpose â€” each side threads through its own
/// transformation, so you can lock in "left follows left, right
/// follows right" under a further algebra step.
pub fn[T, U] Equivalence::bind(
  self : Equivalence[T],
  f : (T) -> Equivalence[U],
) -> Equivalence[U] {
  let lhs = f(self.lhs).lhs
  let rhs = f(self.rhs).rhs
  { lhs, rhs }
}

///|
/// Applicative apply: pair up a pair of functions with a pair of
/// arguments, evaluating each side independently.
pub fn[T, U] Equivalence::ap(
  self : Equivalence[(T) -> U],
  other : Equivalence[T],
) -> Equivalence[U] {
  let lhs = (self.lhs)(other.lhs)
  let rhs = (self.rhs)(other.rhs)
  { lhs, rhs }
}

///|
/// Unit of the `Equivalence` applicative: both sides are the same
/// value `x`. Trivially equal under any relation.
pub fn[T] pure_eq(x : T) -> Equivalence[T] {
  { lhs: x, rhs: x }
}

///|
/// Evaluate the equivalence under structural equality (`Eq`). Returns
/// `true` iff `lhs == rhs`. Shortcut for `equal_by(Eq::equal)`.
pub fn[T : Eq] Equivalence::is_equal(self : Equivalence[T]) -> Bool {
  self.lhs == self.rhs
}

///|
/// Evaluate the equivalence under a user-supplied relation. The
/// relation doesn't need to be symmetric â€” a directional law like
/// "left is a refinement of right" works too.
pub fn[T] Equivalence::equal_by(
  self : Equivalence[T],
  eq : (T, T) -> Bool,
) -> Bool {
  eq(self.lhs, self.rhs)
}

///|
struct Axiom[T] {
  run_axiom : (T) -> Equivalence[T]
}

///|
/// Lift a `T -> Equivalence[T]` function into an `Axiom[T]`. Useful
/// when expressing an algebraic law as "for every input `x`, the
/// equivalence `run_axiom(x)` should hold".
pub fn[T] Axiom::new(run_axiom : (T) -> Equivalence[T]) -> Axiom[T] {
  { run_axiom, }
}

///|
/// Evaluate an axiom at `x` and return the pair of values whose
/// equality the axiom asserts.
pub fn[T] Axiom::run(self : Axiom[T], x : T) -> Equivalence[T] {
  (self.run_axiom)(x)
}

///|
/// Turn an axiom into a property suitable for `quick_check_fn`:
/// for each generated `x`, compute the equivalence, pass both sides
/// through `cong`, then compare using `eq`. Typical use:
///
///     axiom_assoc.to_property(list_to_string, string_eq)
///     |> quick_check_fn
pub fn[T, U] Axiom::to_property(
  self : Axiom[T],
  cong : (T) -> U,
  eq : (U, U) -> Bool,
) -> (T) -> Bool {
  fn(x : T) { self.run(x).fmap(cong).equal_by(eq) }
}

///|
/// Convenience wrapper around `to_property` when `U` has an `Eq`
/// instance â€” uses structural equality as the relation.
pub fn[T, U : Eq] Axiom::to_property_eq(
  self : Axiom[T],
  cong : (T) -> U,
) -> (T) -> Bool {
  self.to_property(cong, Eq::equal)
}

///|
/// Turn an axiom into a *parametric* property: useful when the
/// equivalence depends on an extra environment value `m` that is also
/// generated by QuickCheck. `cong` maps `(T, M) -> N`; the property
/// compares `cong(lhs, m)` against `cong(rhs, m)` using `eq`.
pub fn[T, M, N] Axiom::to_property_parametric(
  self : Axiom[T],
  cong : (T, M) -> N,
  eq : (N, N) -> Bool,
) -> ((T, M)) -> Bool {
  fn(x : (T, M)) { self.run(x.0).fmap(fn(y) { cong(y, x.1) }).equal_by(eq) }
}

///|
/// Convenience wrapper around `to_property_parametric` when `N` has
/// an `Eq` instance.
pub fn[T, M, N : Eq] Axiom::to_property_parametric_eq(
  self : Axiom[T],
  cong : (T, M) -> N,
) -> ((T, M)) -> Bool {
  self.to_property_parametric(cong, Eq::equal)
}
